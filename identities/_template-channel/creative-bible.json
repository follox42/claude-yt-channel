{
  "_schema_version": 1,
  "channel_slug": "__REPLACE_ME__",
  "_note": "Unified style bible — ALL skills read this. One source of truth for the channel's identity (visual, audio, characters, thumbnails). Generated by creative-director skill during onboarding.",

  "visual_format": {
    "primary_style": "__REPLACE_ME__",
    "_options": ["cartoon-flat", "cartoon-3d", "anime", "photorealistic-cinematic", "photorealistic-documentary", "retro-vhs", "comic-book", "watercolor", "pixel-art", "mixed-media", "stock-footage-only", "minimal-text-only"],
    "rationale": "Why this format suits the niche + audience + Higgsfield strengths",
    "reference_channels": [
      {"name": "...", "url": "...", "what_to_borrow": "..."}
    ],
    "color_palette": {
      "primary": "#FF4757",
      "secondary": "#7C3AED",
      "bg": "#0A0A0C",
      "accent": "#FFD700"
    },
    "aspect_ratio": "9:16",
    "duration_range_sec": [45, 60]
  },

  "characters": {
    "mode": "none",
    "_options": ["none", "single-recurring", "small-cast", "narrator-only"],
    "_note": "If single-recurring or small-cast → use Higgsfield Soul ID training. Stores reference_id per character.",
    "cast": []
  },

  "voice": {
    "mode": "text-overlay-only",
    "_options": ["text-overlay-only", "elevenlabs-ai", "human-uploaded", "mixed"],
    "elevenlabs": {
      "voice_id": null,
      "voice_name": null,
      "tone": null,
      "stability": 0.5,
      "similarity_boost": 0.75
    },
    "language": "en",
    "accent": null
  },

  "music": {
    "mode": "stock-library",
    "_options": ["none", "stock-library", "ai-generated-suno", "ai-generated-udio", "human-composed"],
    "stock_library": "pixabay",
    "_library_options": ["pixabay", "youtube-audio-library", "epidemic-sound", "storyblocks"],
    "genre_per_scene_type": {
      "hook": "tense-cinematic-build",
      "buildup": "tense-cinematic-rise",
      "payoff": "epic-orchestral-hit",
      "outro": "subtle-fade"
    },
    "lufs_target": -10,
    "ducking_db": -8
  },

  "asset_sourcing_priority": [
    "higgsfield-soul-id",
    "higgsfield-generic",
    "footage-hunter-stock",
    "footage-hunter-archive"
  ],
  "_priority_note": "Sourcing strategy — first option that returns valid result wins. Soul ID first for character consistency, then generic gen, then stock fallback if Higgsfield credits exhausted.",

  "text_overlay": {
    "font_family": "Impact",
    "font_weight": 900,
    "case": "uppercase",
    "color": "#FFFFFF",
    "stroke_color": "#000000",
    "stroke_width_px": 5,
    "position_default": "top-center",
    "animation_in": "pop-spring",
    "highlight_keyword_color": "#FFD700",
    "max_chars_per_line": 20,
    "min_font_size_pct_of_height": 8
  },

  "captions": {
    "burn_mode": "auto",
    "_options": ["none", "auto", "sidecar-srt"],
    "highlight_word_color": "#FFD700",
    "font_size_pct": 6,
    "position": "bottom-center-25pct"
  },

  "thumbnail_style": {
    "pattern": "face-shock-with-text",
    "_options": ["face-shock-with-text", "before-after-split", "scene-with-arrow", "object-closeup", "text-only-bold"],
    "text_max_words": 5,
    "text_color": "#FFFFFF",
    "text_stroke_color": "#000000",
    "face_emotion_target": "shocked",
    "_face_options": ["shocked", "excited", "scared", "neutral", "smug", "crying"],
    "color_contrast_target": "high",
    "variants_to_generate": 3
  },

  "delivery": {
    "platform_primary": "youtube_shorts",
    "_options": ["youtube_shorts", "youtube_long", "tiktok", "instagram_reels"],
    "fps": 30,
    "bitrate_kbps": 8000,
    "codec": "h264"
  },

  "anti_detect": {
    "vary_thumbnails": true,
    "vary_titles": true,
    "min_hours_between_uploads": 4,
    "max_per_day_per_channel": 3,
    "human_touch_every_n_videos": 3
  }
}
