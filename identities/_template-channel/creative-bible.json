{
  "_schema_version": 2,
  "channel_slug": "__REPLACE_ME__",
  "_note": "Unified style bible — ALL skills read this. Generated by creative-director skill which DERIVES style from successful channels in the niche (not from a fixed enum). The style_signature can be any emergent format.",

  "style_signature": {
    "label": "__DERIVED_FROM_COMPETITORS__",
    "_label_examples": [
      "iphone-imessage-narration",
      "reddit-scroll-dark-mode",
      "subway-surfers-overlay",
      "screenshot-tweet-narration",
      "split-screen-reaction-pop",
      "ai-news-anchor-with-broll",
      "kurzgesagt-flat-vector-explainer",
      "whatsapp-conversation-acted",
      "first-person-pov-walking",
      "stop-motion-toy-figurine",
      "satisfying-mechanical-machine",
      "pixar-storytime",
      "cartoon-flat",
      "anime-cinematic",
      "photorealistic-documentary",
      "retro-vhs-found-footage",
      "comic-book-panels",
      "stock-footage-narration",
      "AND_ANY_OTHER_EMERGENT_PATTERN"
    ],

    "description": "Free-form prose description of the visual look. Written by creative-director after watching 3+ successful outliers. 2-5 sentences. Specific enough that another agent can reproduce.",

    "reference_outliers": [
      {
        "channel_name": "...",
        "video_url": "...",
        "views": 0,
        "subs": 0,
        "what_to_borrow": "specific technique (e.g. 'iPhone bezel overlay', 'red-bold-text-on-yellow', 'scroll-to-beat')"
      }
    ],

    "key_visual_techniques": [
      "List of specific reproducible moves. Examples:",
      "iPhone Messages UI overlay with auto-scroll synced to voiceover",
      "Subway Surfers gameplay loop as bottom 30% of screen",
      "Red arrow + circle highlights on screenshot details",
      "Hand-drawn whiteboard explanations with timelapse",
      "Reddit dark-mode UI with white text + voiceover reading the post",
      "AI character with consistent face (Soul ID) reacting to events"
    ],

    "production_recipe": {
      "primary_tool": "remotion",
      "_options": ["remotion", "higgsfield-only", "footage-hunter-only", "hybrid"],

      "remotion_components": [
        "List of Remotion compositions needed. Examples:",
        "<IPhoneMessagesUI> — iPhone bezel + Messages app template + scroll animation",
        "<SubwaySurfersBackground> — looped gameplay mp4 as bottom layer",
        "<RedditPostScroll> — dark-mode UI + auto-scroll timing"
      ],

      "asset_sources_per_scene_type": {
        "narrator_face": "higgsfield-soul-id (if character defined)",
        "scene_b_roll": "higgsfield-generate (style: {style_signature.label})",
        "ui_screenshots": "generated by Remotion components OR scraped from real apps",
        "background_loop": "footage-hunter (Pexels/Pixabay) OR Minecraft/Subway gameplay archive",
        "emoji_reactions": "Remotion + emoji-mart library (no gen needed)",
        "text_overlays": "Remotion drawText"
      },

      "complexity_score": 3,
      "_complexity_scale": "1 (trivial: text overlay only) → 5 (very complex: needs custom Remotion components + Higgsfield Soul ID + multi-source assets)"
    },

    "color_palette": {
      "primary": "#FF4757",
      "secondary": "#7C3AED",
      "bg": "#0A0A0C",
      "accent": "#FFD700"
    },

    "aspect_ratio": "9:16",
    "duration_range_sec": [45, 60]
  },

  "characters": {
    "mode": "none",
    "_options": ["none", "single-recurring", "small-cast", "narrator-only"],
    "_note": "Required only if style_signature uses recurring characters. Otherwise leave empty.",
    "cast": []
  },

  "voice": {
    "mode": "text-overlay-only",
    "_options": ["text-overlay-only", "elevenlabs-ai", "human-uploaded", "mixed"],
    "elevenlabs": {
      "voice_id": null,
      "voice_name": null,
      "tone": null,
      "stability": 0.5,
      "similarity_boost": 0.75
    },
    "language": "en",
    "accent": null
  },

  "music": {
    "mode": "stock-library",
    "_options": ["none", "stock-library", "ai-generated-suno", "ai-generated-udio", "human-composed"],
    "stock_library": "pixabay",
    "genre_per_scene_type": {
      "hook": "tense-cinematic-build",
      "buildup": "tense-cinematic-rise",
      "payoff": "epic-orchestral-hit",
      "outro": "subtle-fade"
    },
    "lufs_target": -10,
    "ducking_db": -8
  },

  "asset_sourcing_priority": [
    "production_recipe-defined",
    "_note": "When style_signature.production_recipe specifies per-scene-type sources, use that. Otherwise fallback to the global priority below.",
    "higgsfield-soul-id",
    "higgsfield-generic",
    "footage-hunter-stock",
    "footage-hunter-archive",
    "remotion-only"
  ],

  "text_overlay": {
    "font_family": "Impact",
    "font_weight": 900,
    "case": "uppercase",
    "color": "#FFFFFF",
    "stroke_color": "#000000",
    "stroke_width_px": 5,
    "position_default": "top-center",
    "animation_in": "pop-spring",
    "highlight_keyword_color": "#FFD700",
    "max_chars_per_line": 20,
    "min_font_size_pct_of_height": 8
  },

  "captions": {
    "burn_mode": "auto",
    "_options": ["none", "auto", "sidecar-srt"],
    "highlight_word_color": "#FFD700",
    "font_size_pct": 6,
    "position": "bottom-center-25pct"
  },

  "thumbnail_style": {
    "_note": "Also DERIVED from competitor thumbnails — no fixed enum. Free-form pattern label.",
    "pattern_label": "__DERIVED__",
    "pattern_description": "Prose description of the thumbnail look",
    "reference_thumbnails": [
      {"channel": "...", "video_url": "...", "thumbnail_url": "..."}
    ],
    "text_max_words": 5,
    "text_color": "#FFFFFF",
    "text_stroke_color": "#000000",
    "color_contrast_target": "high",
    "variants_to_generate": 3
  },

  "delivery": {
    "platform_primary": "youtube_shorts",
    "_options": ["youtube_shorts", "youtube_long", "tiktok", "instagram_reels"],
    "fps": 30,
    "bitrate_kbps": 8000,
    "codec": "h264"
  },

  "anti_detect": {
    "vary_thumbnails": true,
    "vary_titles": true,
    "min_hours_between_uploads": 4,
    "max_per_day_per_channel": 3,
    "human_touch_every_n_videos": 3
  }
}
