# claude-yt-channel — environment variables
# Copy to config/.env and fill in. The pipeline works with ZERO keys (Tier 0 mode).
# Each key UNLOCKS speed/quality upgrades but none are required.

# ============================================================================
# TIER 0 — Works with no keys at all (default mode)
# ============================================================================
# - Higgsfield CLI authed via `higgsfield auth login` (device flow)
# - footage-hunter uses archive.org + Wikimedia + NASA + YouTube CC (no keys)
# - voice = text-overlay-only (no ElevenLabs needed)
# - music = silence or YT Audio Library (no key)

# ============================================================================
# TIER 1 — Speed/quality upgrades (all OPTIONAL)
# ============================================================================

# Anthropic (uses parent Claude Code auth if empty)
ANTHROPIC_API_KEY=

# Voice — UNLOCKS ElevenLabs voiceover
# Free 10k chars/mo at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Stock APIs — UNLOCKS faster sourcing (else footage-hunter falls back to archive.org scrape)
# Each requires manual signup (anti-bot blocks programmatic):
#   Pexels:   https://www.pexels.com/api/new/ (free, 200 req/h)
#   Pixabay:  https://pixabay.com/api/docs/ (free, 100 req/h, includes audio)
#   Unsplash: https://unsplash.com/oauth/applications/new (free, photos only)
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# AI music — UNLOCKS Suno/Udio music generation (else uses Pixabay audio scrape OR silence)
# Suno Pro: $10/mo at https://suno.com/account
SUNO_API_KEY=
UDIO_API_KEY=

# YouTube Data API v3 — Phase 2 upgrade to replace camoufox upload
# Free at https://console.cloud.google.com (15 min OAuth setup)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# ============================================================================
# Pipeline limits + dashboard
# ============================================================================

MAX_HIGGSFIELD_CREDITS_PER_RUN=8
MAX_TOTAL_RUN_BUDGET_EUR=2.0
MAX_UPLOADS_PER_DAY_PER_CHANNEL=3
MIN_HOURS_BETWEEN_UPLOADS=4

DASHBOARD_PORT=3737
DASHBOARD_DB=./data/runs.db

# ============================================================================
# Cost summary
# ============================================================================
# Tier 0 (zero keys):           0 EUR/mo — ~3 Shorts (Higgsfield free 10cr)
# Tier 1 minimal (HF Premium):  15 EUR/mo — ~50 Shorts, no voice
# Tier 1 + voice:               20 EUR/mo — ~10 Shorts with ElevenLabs voiceover
# Tier 1 + voice + music:       30 EUR/mo — ~10 Shorts with Suno AI music
# Pro multi-channel:           150 EUR/mo — scaled production across 3-5 channels
